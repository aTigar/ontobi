{
  "name": "@ontobi/core",
  "version": "0.1.0",
  "description": "Standalone SKOS knowledge graph engine — parser, Oxigraph RDF store, SPARQL endpoint, CLI",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ontobi": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "n3": "^2.0.1",
    "oxigraph": "^0.5.5"
  },
  "devDependencies": {
    "@types/n3": "^1.26.1",
    "@types/node": "^20.0.0",
    "vitest": "^3.0.0"
  }
}
